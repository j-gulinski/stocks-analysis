# Copy to .env.local (gitignored). Values are read server-side only.

# FastAPI backend (local dev). In production this is the Railway URL.
BACKEND_URL=http://localhost:8000

# Phase 6 (production only) — static bearer token shared with the backend:
# BACKEND_API_TOKEN=

# Phase 6 (production only) — Auth.js Google allowlist:
# AUTH_SECRET=
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# ALLOWED_EMAILS=you@example.com,friend@example.com
