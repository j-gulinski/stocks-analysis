# Copy to .env and fill in. The .env file is gitignored — secrets never enter the repo.

DATABASE_URL=postgresql+psycopg://stocks:stocks@localhost:5433/stocks

# PortalAnaliz forum credentials (your own account; used only in-process, never stored)
# NOTE: values with special characters (# $ " spaces) must be double-quoted:
#   PA_PASSWORD="p@ss #123"
PA_USERNAME=
PA_PASSWORD=

# BiznesRadar premium session (task P1.9). A premium BR account unlocks longer
# report/price history. A logged-in session is optional: leaving these blank
# refreshes fully anonymously, exactly as before P1.9.
# Login recipe verified live 2026-07-08: POST /login/ with email + password,
# success confirmed by the 'account-settings' homepage marker (see
# app/scrapers/biznesradar.py BrClient). Check it via GET
# /api/diagnostics/br-login-status.
# BR_USERNAME = adres e-mail konta BiznesRadar
BR_USERNAME=
BR_PASSWORD=

# Claude API (Phase 5 verdict product; also the optional WP2b thesis refiner).
# No key => the thesis refiner is a transparent pass-through to the deterministic
# read (engine: "deterministic"); it never errors when unset.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# WP2b iterative thesis refiner (services/thesis_ai.py):
#   ANTHROPIC_MAX_ITERATIONS - bounded refinement rounds per call (small = cheap)
#   AI_CACHE_ENABLED         - cache refinements under backend/.cache/thesis_ai/
ANTHROPIC_MAX_ITERATIONS=2
AI_CACHE_ENABLED=true

# Cheap model for the forum distiller (P5.9) — classifies already-synced posts
# into confidence-labelled claims; separate from ANTHROPIC_MODEL (verdict model).
AI_DISTILL_MODEL=claude-haiku-4-5

# Production only (Phase 6): static bearer token shared with the Vercel proxy
# API_TOKEN=

# Global daily cap on AI analysis runs (cost guard)
# AI_DAILY_LIMIT=20
